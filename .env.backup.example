# Restic backend (example for S3-compatible storage)
RESTIC_REPOSITORY="s3:https://s3.example.com/backup-bucket/docker-compose"
RESTIC_PASSWORD="replace-with-strong-passphrase"
AWS_ACCESS_KEY_ID="replace-with-access-key"
AWS_SECRET_ACCESS_KEY="replace-with-secret-key"
AWS_DEFAULT_REGION="us-east-1"

# Optional backup behavior
BACKUP_TAG="docker-compose"
BACKUP_HOST="host-01"
KEEP_DAILY="7"
KEEP_WEEKLY="4"
KEEP_MONTHLY="6"
RUN_FORGET_PRUNE="1"
KEEP_STAGING_LOCAL="0"
