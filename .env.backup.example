# Restic backend (Cloudflare R2, S3-compatible)
# Format: s3:https://<account_id>.r2.cloudflarestorage.com/<bucket_name>
RESTIC_REPOSITORY="s3:https://<account_id>.r2.cloudflarestorage.com/<bucket_name>"
RESTIC_PASSWORD="replace-with-strong-passphrase"
AWS_ACCESS_KEY_ID="replace-with-access-key"
AWS_SECRET_ACCESS_KEY="replace-with-secret-key"
AWS_DEFAULT_REGION="auto"

# Optional backup behavior
BACKUP_TAG="docker-compose"
BACKUP_HOST="host-01"
KEEP_DAILY="7"
KEEP_WEEKLY="4"
KEEP_MONTHLY="6"
RUN_FORGET_PRUNE="1"
KEEP_STAGING_LOCAL="0"
